from dotenv import load_dotenv
load_dotenv()

import os
import json
import asyncio
from typing import Dict, Optional

from fastapi import FastAPI, WebSocket
from fastapi.middleware.cors import CORSMiddleware

import azure.cognitiveservices.speech as speechsdk


# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
app = FastAPI()

# CORS: poziva se iz browser/Electron renderera. Ne koristimo cookies/credentials.
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=False,   # MUST be False when allow_origins=["*"]
    allow_methods=["*"],
    allow_headers=["*"],
)


# ------------------------------------------------------------
# ENV
# ------------------------------------------------------------
AZURE_SPEECH_KEY = os.environ["AZURE_SPEECH_KEY"]
AZURE_SPEECH_REGION = os.environ["AZURE_SPEECH_REGION"]

# Default jezik kada nema override-a ili kada je override nevalidan
STT_DEFAULT_LANGUAGE = os.getenv("STT_DEFAULT_LANGUAGE", "en-US").strip()

# Podržani jezici (manual override + default)
SUPPORTED_LANGS = {"en-US", "sr-RS", "es-ES", "de-DE"}

# Ako default nije u listi, prisilno postavi na en-US
if STT_DEFAULT_LANGUAGE not in SUPPORTED_LANGS:
    STT_DEFAULT_LANGUAGE = "en-US"


def make_speech_config() -> speechsdk.SpeechConfig:
    """Per-connection SpeechConfig (bez cross-session 'leak-a')."""
    cfg = speechsdk.SpeechConfig(subscription=AZURE_SPEECH_KEY, region=AZURE_SPEECH_REGION)

    # Stabilniji FINAL segmenti
    cfg.set_property(speechsdk.PropertyId.Speech_SegmentationSilenceTimeoutMs, "800")
    cfg.set_property(speechsdk.PropertyId.SpeechServiceConnection_InitialSilenceTimeoutMs, "3000")

    return cfg


# ------------------------------------------------------------
# ACTIVE SESSIONS
# ------------------------------------------------------------
_active_sessions: Dict[str, speechsdk.SpeechRecognizer] = {}


# ------------------------------------------------------------
# STT WEBSOCKET
# ------------------------------------------------------------
@app.websocket("/stt/ws/{session_id}")
async def stt_ws(ws: WebSocket, session_id: str):
    await ws.accept()
    loop = asyncio.get_running_loop()

    # Optional manual override:
    # /stt/ws/{session_id}?lang=sr-RS
    requested_lang: Optional[str] = ws.query_params.get("lang")
    if requested_lang:
        requested_lang = requested_lang.strip()

    # Enforce only supported langs; fallback to default English (or env default)
    effective_lang = requested_lang if (requested_lang in SUPPORTED_LANGS) else STT_DEFAULT_LANGUAGE

    # Push stream (PCM16 @ 16kHz mono)
    audio_format = speechsdk.audio.AudioStreamFormat(
        samples_per_second=16000,
        bits_per_sample=16,
        channels=1,
    )
    push_stream = speechsdk.audio.PushAudioInputStream(audio_format)
    audio_config = speechsdk.audio.AudioConfig(stream=push_stream)

    # Per-connection config
    speech_config = make_speech_config()
    speech_config.speech_recognition_language = effective_lang

    recognizer = speechsdk.SpeechRecognizer(
        speech_config=speech_config,
        audio_config=audio_config,
    )

    _active_sessions[session_id] = recognizer

    # Debug info (ne menja UI logiku)
    await ws.send_text(
        json.dumps(
            {
                "type": "STT_MODE",
                "sessionId": session_id,
                "mode": "fixed",
                "language": effective_lang,
                "supported": sorted(list(SUPPORTED_LANGS)),
            }
        )
    )

    # ----------------------------
    # EVENT HANDLERS
    # ----------------------------
    def on_recognized(evt):
        if evt.result.reason == speechsdk.ResultReason.RecognizedSpeech:
            text = (evt.result.text or "").strip()
            if text:
                payload = {
                    "type": "STT_FINAL",
                    "sessionId": session_id,
                    "transcript": text,
                    "lang": effective_lang,
                }
                asyncio.run_coroutine_threadsafe(ws.send_text(json.dumps(payload)), loop)

    def on_canceled(evt):
        asyncio.run_coroutine_threadsafe(
            ws.send_text(
                json.dumps(
                    {
                        "type": "STT_ERROR",
                        "sessionId": session_id,
                        "error": str(evt),
                    }
                )
            ),
            loop,
        )

    recognizer.recognized.connect(on_recognized)
    recognizer.canceled.connect(on_canceled)

    recognizer.start_continuous_recognition()

    try:
        while True:
            data = await ws.receive_bytes()
            push_stream.write(data)
    except Exception:
        # uključuje disconnect
        pass
    finally:
        try:
            recognizer.stop_continuous_recognition()
        except Exception:
            pass
        try:
            push_stream.close()
        except Exception:
            pass
        _active_sessions.pop(session_id, None)

