# CHATT backend local development environment example
# Copy this file to:
#   C:\Projects\chatt\backend\.env
#
# Do not commit real secrets.
# Fill real values only in backend\.env.

# ---------------------------------------------------------------------
# Azure Speech / STT
# ---------------------------------------------------------------------
AZURE_SPEECH_KEY=<your-azure-speech-key>
AZURE_SPEECH_REGION=eastus2

# Legacy aliases used by parts of the current project.
# Keep these aligned with AZURE_SPEECH_* values.
SPEECH_KEY=<your-azure-speech-key>
SPEECH_REGION=eastus2
SPEECH_LANG=en-US
SPEECH_SAMPLE_RATE=16000

# STT tuning
# Important: local working value should match the deployed Container App.
STT_SEGMENTATION_STRATEGY=Default
STT_SEGMENTATION_SILENCE_TIMEOUT_MS=2000
STT_END_SILENCE_TIMEOUT_MS=2500
STT_INITIAL_SILENCE_TIMEOUT_MS=4000
STT_SEGMENTATION_MAXIMUM_TIME_MS=45000
STT_RECO_MODE=Conversation
STT_STABLE_PARTIAL_THRESHOLD=3
STT_CONTEXT_FLUSH_SILENCE_MS=2500
STT_DEFAULT_LANGUAGE=en-US

# ---------------------------------------------------------------------
# Agent1 / Azure AI Foundry Agent
# ---------------------------------------------------------------------
AGENT1_PROJECT_ENDPOINT=https://agentfield.services.ai.azure.com/api/projects/proj-default
AGENT1_AGENT_ID=asst_sS6A4EFTSyKUSbKpRh8v5rXu

# Legacy aliases kept for compatibility/reference.
# Current orchestrator code reads AGENT1_PROJECT_ENDPOINT and AGENT1_AGENT_ID.
AZURE_AI_PROJECT_ENDPOINT=https://agentfield.services.ai.azure.com/api/projects/proj-default
AGENT1_ID=asst_sS6A4EFTSyKUSbKpRh8v5rXu

# ---------------------------------------------------------------------
# Azure OpenAI Realtime voice
# ---------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://agentfield.cognitiveservices.azure.com
AZURE_OPENAI_KEY=<your-azure-openai-key>
AZURE_OPENAI_MODEL=gpt-realtime-mini
AZURE_OPENAI_API_VERSION=2025-05-01-preview
AZURE_OPENAI_PROFILE=byom-azure-openai-realtime

REALTIME_SAMPLE_RATE=24000
AUDIO_CHANNELS=1

# ---------------------------------------------------------------------
# Instructions / profiles
# Paths are relative to C:\Projects\chatt\backend when services start there.
# ---------------------------------------------------------------------
INSTRUCTIONS_PATH=instructions.json
INSTRUCTION_PROFILES_PATH=instruction_profiles.json
MAX_INSTRUCTIONS_LEN=8192

# ---------------------------------------------------------------------
# Runtime ports
# Usually passed explicitly by uvicorn commands.
# ---------------------------------------------------------------------
PORT=50505

# ---------------------------------------------------------------------
# Debug
# ---------------------------------------------------------------------
DEBUG=false
