# CHATT Direct backend local development environment example
# Copy this file to:
#   C:\Projects\chatt-direct\backend\.env
#
# Do not commit real secrets.
# Fill real values only in backend\.env.

# ---------------------------------------------------------------------
# Azure OpenAI Realtime voice
# ---------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://agentfield.cognitiveservices.azure.com
AZURE_OPENAI_KEY=<your-azure-openai-key>
AZURE_OPENAI_MODEL=gpt-realtime-2
AZURE_OPENAI_API_VERSION=2025-05-01-preview
AZURE_OPENAI_PROFILE=byom-azure-openai-realtime
XAI_API_KEY=<your-xai-api-key>
XAI_GROK_REALTIME_MODEL=grok-voice-think-fast-1.0
GOOGLE_GEMINI_API_KEY=<your-google-gemini-api-key>
GOOGLE_GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

REALTIME_SAMPLE_RATE=24000
AUDIO_CHANNELS=1

# ---------------------------------------------------------------------
# Instructions
# ---------------------------------------------------------------------
INSTRUCTIONS_PATH=instructions.json
MAX_INSTRUCTIONS_LEN=8192


# ---------------------------------------------------------------------
# Local development runtime files
# ---------------------------------------------------------------------
PROVIDER_CONFIG_PATH=provider_config.local.json
PROVIDER_CAPABILITIES_PATH=provider_capabilities.json
PROVIDER_CONFIG_EXAMPLE_PATH=provider_config.local.example.json
SCENARIO_PRESETS_PATH=scenario_presets.local.json
SCENARIO_PRESETS_DEFAULT_PATH=scenario_presets.json

# ---------------------------------------------------------------------
# Runtime port
# ---------------------------------------------------------------------
PORT=50505

# ---------------------------------------------------------------------
# Debug
# ---------------------------------------------------------------------
DEBUG=false
